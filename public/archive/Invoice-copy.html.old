<!DOCTYPE html>
<html>
<head>
  <title>WorkHQ Mock Invoice Event Sender</title>
  <style>
    :root {
      --navy: #071a63;
      --deep-navy: #041044;
      --blue: #2078ff;
      --cyan: #18d7e5;
      --aqua: #5ff0e6;
      --white: #ffffff;
      --muted: #b7c4e8;
      --card: rgba(255, 255, 255, 0.08);
      --border: rgba(255, 255, 255, 0.18);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Segoe UI", Arial, sans-serif;
      color: var(--white);
      background:
        radial-gradient(circle at 12% 12%, rgba(24, 215, 229, 0.35), transparent 28%),
        radial-gradient(circle at 82% 20%, rgba(32, 120, 255, 0.35), transparent 30%),
        linear-gradient(135deg, var(--deep-navy), var(--navy));
      padding: 36px;
    }

    .shell {
      max-width: 1050px;
      margin: auto;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 18px;
      margin-bottom: 28px;
    }

    .brand-mark {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      background:
        radial-gradient(circle at center, #26128a 0 34%, transparent 35%),
        conic-gradient(from 220deg, var(--cyan), var(--blue), #dff7ff, var(--cyan));
      box-shadow: 0 0 30px rgba(24, 215, 229, 0.65);
      position: relative;
    }

    .brand-mark::after {
      content: "▲";
      position: absolute;
      color: white;
      font-size: 34px;
      left: 18px;
      top: 16px;
      transform: rotate(0deg);
    }

    .brand h1 {
      margin: 0;
      font-size: 42px;
      letter-spacing: -1px;
    }

    .brand span {
      display: block;
      font-size: 18px;
      color: var(--muted);
      margin-bottom: 2px;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 22px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 24px;
      backdrop-filter: blur(14px);
      box-shadow: 0 18px 50px rgba(0, 0, 0, 0.28);
    }

    .card h2 {
      margin-top: 0;
      font-size: 22px;
    }

    .invoice-row {
      display: flex;
      justify-content: space-between;
      border-bottom: 1px solid rgba(255,255,255,0.12);
      padding: 11px 0;
      color: var(--muted);
    }

    .invoice-row strong {
      color: white;
    }

    .event {
      display: block;
      padding: 14px 16px;
      margin: 10px 0;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.07);
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .event:hover {
      border-color: var(--cyan);
      box-shadow: 0 0 18px rgba(24, 215, 229, 0.25);
      transform: translateY(-1px);
    }

    .event input {
      margin-right: 10px;
      accent-color: var(--cyan);
    }

    button {
      width: 100%;
      margin-top: 16px;
      padding: 15px 18px;
      border: none;
      border-radius: 16px;
      color: white;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      background: linear-gradient(90deg, var(--cyan), var(--blue));
      box-shadow: 0 0 26px rgba(24, 215, 229, 0.35);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 0 36px rgba(24, 215, 229, 0.55);
    }

    pre {
      min-height: 180px;
      background: rgba(1, 8, 35, 0.72);
      color: #d8fff8;
      padding: 16px;
      border-radius: 16px;
      border: 1px solid rgba(95, 240, 230, 0.25);
      overflow: auto;
      font-size: 13px;
    }

    .full {
      grid-column: 1 / -1;
    }

    .status-pill {
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(24, 215, 229, 0.16);
      color: var(--aqua);
      font-size: 13px;
      border: 1px solid rgba(24, 215, 229, 0.35);
    }

    @media (max-width: 850px) {
      .grid {
        grid-template-columns: 1fr;
      }

      .brand h1 {
        font-size: 32px;
      }
    }
  </style>
</head>
<body>

<div class="shell">
  <div class="brand">
    <img src="../assets/logo.jpg" class="brand-logo">
    <div>
      <span>SS&C Blue Prism</span>
      <h1>WorkHQ Invoice Event Sender</h1>
    </div>
  </div>

  <div class="card full">
    <h2>Invoices</h2>

    <table>
      <thead>
        <tr>
          <th><input type="checkbox" id="selectAll" onchange="toggleSelectAll()"></th>
          <th>Invoice</th>
          <th>Supplier</th>
          <th>Country</th>
          <th>Amount</th>
          <th>Status</th>
          <th>Event</th>
        </tr>
      </thead>
      <tbody id="invoiceTable"></tbody>
    </table>

    <button onclick="sendSelectedInvoices()">Send Selected to WorkHQ</button>
  </div>

  <div class="grid">
    <div class="card">
      <h2>Payload Sent</h2>
      <pre id="payloadOutput">Nothing sent yet.</pre>
    </div>

    <div class="card">
      <h2>Webhook Response</h2>
      <pre id="responseOutput">No response yet.</pre>
    </div>
  </div>
</div>

<script>
const WEBHOOK_URL = "https://presales.nextgen.blueprism.com/regions/eu-central/api/workflows/v1/webhooks/xKEZYznqXRZZy8o3ARPkn/sync";
const BEARER_TOKEN = "PASTE_YOUR_BEARER_TOKEN_HERE";

function getSelectedEvent() {
  return document.querySelector('input[name="eventType"]:checked').value;
}

function createPayload() {
  const eventType = getSelectedEvent();

  return {
    eventId: "EVT-" + crypto.randomUUID(),
    eventType,
    receivedAt: new Date().toISOString(),
    invoice: {
      invoiceId: "INV-10045",
      supplierName: "Acme Trading LLC",
      supplierCountry: "AE",
      amount: 12500.75,
      currency: "AED",
      status: "Pending Review"
    },
    request: {
      priority: eventType === "invoice_rejected" ? "high" : "medium",
      requiresApproval: eventType === "invoice_received",
      source: "mock-invoice-html"
    }
  };
}

async function sendEvent() {
  const payload = createPayload();

  document.getElementById("payloadOutput").textContent =
    JSON.stringify(payload, null, 2);

  try {
    const response = await fetch(WEBHOOK_URL, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": `Bearer ${BEARER_TOKEN}`,
        "bob": "1234"
      },
      body: JSON.stringify(payload)
    });

    const responseText = await response.text();

    document.getElementById("responseOutput").textContent =
      "Status: " + response.status + "\n\n" + responseText;

  } catch (error) {
    document.getElementById("responseOutput").textContent =
      "Error:\n" + error;
  }
}
</script>

</body>
</html>
