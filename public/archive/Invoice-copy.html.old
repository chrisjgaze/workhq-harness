<!DOCTYPE html>
<html>
<head>
  <title>WorkHQ Mock Invoice Event Sender</title>
    <script src="../scripts/theme-switcher.js"></script>
    <link rel="stylesheet" href="../styles/theme.css" />
    <link rel="stylesheet" href="../styles/base.css" />
  <style>

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Segoe UI", Arial, sans-serif;
      color: var(--text);
      background: var(--app-background);
      padding: 36px;
    }

    .shell {
      max-width: 1050px;
      margin: auto;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 18px;
      margin-bottom: 28px;
    }

    .brand-mark {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      background:
        radial-gradient(circle at center, var(--legacy-mark-core) 0 34%, transparent 35%),
        conic-gradient(from 220deg, var(--cyan), var(--blue), var(--legacy-mark-light), var(--cyan));
      box-shadow: 0 0 30px rgba(var(--cyan-rgb), 0.65);
      position: relative;
    }

    .brand-mark::after {
      content: "▲";
      position: absolute;
      color: var(--text);
      font-size: 34px;
      left: 18px;
      top: 16px;
      transform: rotate(0deg);
    }

    .brand h1 {
      margin: 0;
      font-size: 42px;
      letter-spacing: -1px;
    }

    .brand span {
      display: block;
      font-size: 18px;
      color: var(--muted);
      margin-bottom: 2px;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 22px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 24px;
      backdrop-filter: blur(14px);
      box-shadow: var(--shadow);
    }

    .card h2 {
      margin-top: 0;
      font-size: 22px;
    }

    .invoice-row {
      display: flex;
      justify-content: space-between;
      border-bottom: 1px solid var(--row-border);
      padding: 11px 0;
      color: var(--muted);
    }

    .invoice-row strong {
      color: var(--text);
    }

    .event {
      display: block;
      padding: 14px 16px;
      margin: 10px 0;
      border-radius: 14px;
      border: 1px solid rgba(var(--white-rgb), 0.15);
      background: var(--row-hover-strong);
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .event:hover {
      border-color: var(--cyan);
      box-shadow: 0 0 18px rgba(var(--cyan-rgb), 0.25);
      transform: translateY(-1px);
    }

    .event input {
      margin-right: 10px;
      accent-color: var(--cyan);
    }

    button {
      width: 100%;
      margin-top: 16px;
      padding: 15px 18px;
      border: none;
      border-radius: 16px;
      color: var(--button-text);
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      background: var(--button-gradient);
      box-shadow: 0 0 26px rgba(var(--cyan-rgb), 0.35);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 0 36px rgba(var(--cyan-rgb), 0.55);
    }

    pre {
      min-height: 180px;
      background: var(--field);
      color: var(--code-text);
      padding: 16px;
      border-radius: 16px;
      border: 1px solid rgba(var(--aqua-rgb), 0.25);
      overflow: auto;
      font-size: 13px;
    }

    .full {
      grid-column: 1 / -1;
    }

    .status-pill {
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--aqua);
      font-size: 13px;
      border: 1px solid rgba(var(--cyan-rgb), 0.35);
    }

    @media (max-width: 850px) {
      .grid {
        grid-template-columns: 1fr;
      }

      .brand h1 {
        font-size: 32px;
      }
    }
  </style>
</head>
<body>

<div class="shell">
  <div class="brand">
    <img src="../assets/logo.jpg" class="brand-logo" data-theme-logo data-default-logo="../assets/logo.jpg">
    <div>
      <span>SS&C Blue Prism</span>
      <h1>WorkHQ Invoice Event Sender</h1>
    </div>
  </div>

  <div class="card full">
    <h2>Invoices</h2>

    <table>
      <thead>
        <tr>
          <th><input type="checkbox" id="selectAll" onchange="toggleSelectAll()"></th>
          <th>Invoice</th>
          <th>Supplier</th>
          <th>Country</th>
          <th>Amount</th>
          <th>Status</th>
          <th>Event</th>
        </tr>
      </thead>
      <tbody id="invoiceTable"></tbody>
    </table>

    <button onclick="sendSelectedInvoices()">Send Selected to WorkHQ</button>
  </div>

  <details class="collapsible-output">
    <summary><span class="summary-kicker">Output</span><span class="summary-title">Payload and Response</span><span class="summary-toggle" aria-hidden="true"></span></summary>
    <div class="grid">
      <div class="card">
        <h2>Payload Sent</h2>
        <pre id="payloadOutput">Nothing sent yet.</pre>
      </div>

      <div class="card">
        <h2>Webhook Response</h2>
        <pre id="responseOutput">No response yet.</pre>
      </div>
    </div>
  </details>
</div>

<script>
const WEBHOOK_URL = "https://presales.nextgen.blueprism.com/regions/eu-central/api/workflows/v1/webhooks/xKEZYznqXRZZy8o3ARPkn/sync";
const BEARER_TOKEN = "PASTE_YOUR_BEARER_TOKEN_HERE";

function getSelectedEvent() {
  return document.querySelector('input[name="eventType"]:checked').value;
}

function createPayload() {
  const eventType = getSelectedEvent();

  return {
    eventId: "EVT-" + crypto.randomUUID(),
    eventType,
    receivedAt: new Date().toISOString(),
    invoice: {
      invoiceId: "INV-10045",
      supplierName: "Acme Trading LLC",
      supplierCountry: "AE",
      amount: 12500.75,
      currency: "AED",
      status: "Pending Review"
    },
    request: {
      priority: eventType === "invoice_rejected" ? "high" : "medium",
      requiresApproval: eventType === "invoice_received",
      source: "mock-invoice-html"
    }
  };
}

async function sendEvent() {
  const payload = createPayload();

  document.getElementById("payloadOutput").textContent =
    JSON.stringify(payload, null, 2);

  try {
    const response = await fetch(WEBHOOK_URL, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": `Bearer ${BEARER_TOKEN}`,
        "bob": "1234"
      },
      body: JSON.stringify(payload)
    });

    const responseText = await response.text();

    document.getElementById("responseOutput").textContent =
      "Status: " + response.status + "\n\n" + responseText;

  } catch (error) {
    document.getElementById("responseOutput").textContent =
      "Error:\n" + error;
  }
}
</script>

</body>
</html>
